{
    "name": "chancegarcia/release-scribe",
    "description": "ReleaseScribe: \"What's new\", changelog, release notes, and SemVer recommendation tool",
  "minimum-stability": "stable",
  "prefer-stable": true,
    "type": "project",
    "keywords": [
        "release notes",
        "changelog",
        "whats-new",
        "semver",
        "release recommendation"
    ],
    "homepage": "https://github.com/chancegarcia/release-scribe",
    "license": "Apache-2.0",
    "authors": [
        {
            "name": "chance garcia",
            "email": "develop@chancegarcia.com",
            "homepage": "https://chancegarcia.com"
        }
    ],
    "support": {
        "docs": "https://github.com/chancegarcia/release-scribe",
        "issues": "https://github.com/chancegarcia/release-scribe/issues",
        "source": "https://github.com/chancegarcia/release-scribe"

    },
    "require": {
      "php": ">=8.4",
      "symfony/console": "^7.4 || ^8.0",
      "czproject/git-php": "^4.1",
      "symfony/dotenv": "^8.0"
    },
    "require-dev": {
        "roave/security-advisories": "dev-master",
      "phpunit/phpunit": "^11.0",
      "squizlabs/php_codesniffer": "^3.11",
      "php-coveralls/php-coveralls": "^2.7",
      "php-parallel-lint/php-parallel-lint": "^1.4",
      "php-parallel-lint/php-console-highlighter": "^1.0",
      "phpstan/phpstan": "^1.12",
      "slevomat/coding-standard": "^8.15"
    },
  "scripts": {
      "test": "phpunit",
      "test:coverage": "phpunit --coverage-html build/coverage",
      "lint": "parallel-lint src tests",
      "cs:check": "phpcs src tests --standard=phpcs.xml.dist",
      "cs:fix": "phpcbf src tests --standard=phpcs.xml.dist",
      "stan": "phpstan analyse src tests --level 5",
      "qa": [
        "@lint",
        "@cs:check",
        "@stan",
        "@test"
      ]
    },
    "bin": [
        "bin/release-scribe"
    ],
    "autoload": {
        "psr-4": {
            "Chance\\ReleaseScribe\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Chance\\ReleaseScribe\\Test\\": "tests"
        }
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
