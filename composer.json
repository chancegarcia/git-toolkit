{
    "name": "chancegarcia/git-toolkit",
    "description": "create a change log based on your commit history and tags",
  "minimum-stability": "stable",
  "prefer-stable": true,
    "type": "project",
    "keywords": [
        "git tags",
        "commit history",
        "change log"
    ],
    "homepage": "https://github.com/chancegarcia/git-toolkit",
    "license": "MIT",
    "authors": [
        {
            "name": "chance garcia",
            "email": "develop@chancegarcia.com",
            "homepage": "https://chancegarcia.com"
        }
    ],
    "support": {
        "issues": "https://github.com/chancegarcia/git-toolkit/issues",
        "source": "https://github.com/chancegarcia/git-toolkit"
    },
    "require": {
      "php": ">=8.4",
      "symfony/console": "^7.4 || ^8.0",
      "czproject/git-php": "^4.1"
    },
    "require-dev": {
        "roave/security-advisories": "dev-master",
      "phpunit/phpunit": "^11.0",
      "squizlabs/php_codesniffer": "^3.11",
      "php-coveralls/php-coveralls": "^2.7",
      "php-parallel-lint/php-parallel-lint": "^1.4",
      "php-parallel-lint/php-console-highlighter": "^1.0",
      "phpstan/phpstan": "^1.12"
    },
  "scripts": {
    "test": "phpunit",
    "test:coverage": "phpunit --coverage-html build/coverage",
    "lint": "parallel-lint src tests",
    "cs": "phpcs src tests --standard=PSR12",
    "cs:fix": "phpcbf src tests --standard=PSR12",
    "stan": "phpstan analyse src tests --level 5",
    "qa": [
      "@lint",
      "@cs",
      "@stan",
      "@test"
    ]
    },
    "bin": [
        "bin/toolkit"
    ],
    "autoload": {
        "psr-4": {
            "Chance\\GitToolkit\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Chance\\GitToolkit\\Test\\": "tests"
        }
    }
}
