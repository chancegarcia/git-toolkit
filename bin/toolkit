$currentDir = getcwd();

require $currentDir . '/vendor/autoload.php';

use Chance\GitToolkit\Environment;

Environment::load($currentDir);

$configFile = $currentDir . '/config/chancegarcia_git_toolkit.php';
$dirConfigExists = false;
$projectName = $_ENV['PROJECT_NAME'] ?? null;
$outputFilename = $_ENV['OUTPUT_FILENAME'] ?? null;
$outputPath = $_ENV['OUTPUT_DIRECTORY'] ?? null;
$dir = $_ENV['PROJECT_ROOT'] ?? $currentDir;

if (file_exists($configFile)) {
    /**
     * @var array $config
     */
    $config = require $configFile;
    $dirConfigExists = array_key_exists('project_root', $config);
    if (array_key_exists('project_name', $config)) {
        $projectName = $config['project_name'];
    }

    if (array_key_exists('filename', $config)) {
        $outputFilename = $config['filename'];
    }

    if (array_key_exists('output_directory', $config)) {
        $outputPath = $config['output_directory'];
    }

    if ($dirConfigExists) {
        $dir = $config['project_root'];
    }
}

if (!$dirConfigExists && !isset($_ENV['PROJECT_ROOT'])) {
    if (false !== strpos($currentDir, 'bin')) {
        $dir = $currentDir . '/..';
    }
}

use Symfony\Component\Console\Application;
use Chance\GitToolkit\GitInformation;
use Chance\GitToolkit\Command\ChangeLog;
use Chance\GitToolkit\Command\Init;
use Chance\GitToolkit\Command\Release;
use Chance\GitToolkit\Command\ReleaseRecommend;
use Chance\GitToolkit\Service\ConfigReader;
use Chance\GitToolkit\Service\GeneratorFactory;
use Chance\GitToolkit\Service\ChangeLogService;
use Chance\GitToolkit\Service\GitRepositoryFactory;
use Chance\GitToolkit\Service\ReleaseRecommender;
use Symfony\Component\Console\Command\Command;

$application = new Application('Chance Git Toolkit', '1.0.0');

$gitRepoFactory = new GitRepositoryFactory($dir);
$gitInformation = new GitInformation($gitRepoFactory);

$configMap = [];
if (isset($config) && is_array($config)) {
    // Map existing config to what ConfigReader expects if necessary
    // For now, ConfigReader checks env too.
    $configMap = $config;
}

$configReader = new ConfigReader($configMap);
$generatorFactory = new GeneratorFactory($configReader);
$changeLogService = new ChangeLogService($gitInformation, $generatorFactory);

$changeLogService->setChangeLogFileName($outputFilename);
$changeLogService->setChangeLogFilePath($outputPath);
$changeLogService->setMainHeaderName($projectName);

// ensure Symfony Console properly handles help and arguments for invokable command classes.
$changeLogCommand = new ChangeLog($changeLogService);
$changeLogWrapper = new Command('toolkit:changelog');
$changeLogWrapper->setCode($changeLogCommand);
$changeLogCommand->configure($changeLogWrapper);

$initCommand = new Init($changeLogService);
$initWrapper = new Command('toolkit:init');
$initWrapper->setCode($initCommand);
$initCommand->configure($initWrapper);

$releaseCommand = new Release();
$releaseWrapper = new Command('toolkit:release');
$releaseWrapper->setCode($releaseCommand);

$releaseRecommender = new ReleaseRecommender();
$recommendCommand = new ReleaseRecommend($gitInformation, $releaseRecommender);
$recommendWrapper = new Command('toolkit:release:recommend');
$recommendWrapper->setCode($recommendCommand);
$recommendCommand->configure($recommendWrapper);

$application->addCommands([$changeLogWrapper, $initWrapper, $releaseWrapper, $recommendWrapper]);

$application->run();
